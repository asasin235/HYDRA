{
  "name": "hydra",
  "version": "1.0.0",
  "description": "HYDRA — Personal AI Operating System",
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "pm2 start ecosystem.config.cjs",
    "dev": "pm2 start ecosystem.config.cjs --only start-mvp",
    "setup": "node scripts/setup.js",
    "stop": "pm2 stop all",
    "logs": "pm2 logs",
    "status": "pm2 status",
    "dashboard:dev": "vite --config dashboard/vite.config.ts",
    "dashboard:build": "vite build --config dashboard/vite.config.ts",
    "dashboard:typecheck": "tsc --noEmit --project dashboard/tsconfig.frontend.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "backfill:ruvector": "node scripts/backfill-lancedb-to-ruvector.js",
    "replay:ruvector": "node scripts/replay-ruvector-retry-queue.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ci": "vitest run --coverage",
    "coverage": "vitest run --coverage"
  },
  "keywords": [
    "ai",
    "agents",
    "personal-os"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@lancedb/lancedb": "^0.15.0",
    "@sentry/node": "^10.40.0",
    "@slack/bolt": "^4.1.0",
    "axios": "^1.7.0",
    "better-sqlite3": "^11.7.0",
    "busboy": "^1.6.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "fs-extra": "^11.2.0",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "newrelic": "^13.14.0",
    "node-cron": "^3.0.3",
    "openai": "^4.77.0",
    "pm2": "^5.4.0",
    "pm2-prometheus-exporter": "^0.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "ruvector": "^0.2.11",
    "uuid": "^11.0.0",
    "winston": "^3.19.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.0.18"
  }
}
